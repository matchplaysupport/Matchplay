APP_ENV=development
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-anon-key
EXPO_PUBLIC_USE_MOCK_AUTH=true
EXPO_PUBLIC_USE_MOCK_ENTITLEMENTS=true
# Get a key at golfcourseapi.com — placeholder only, never commit a real key here
EXPO_PUBLIC_GOLF_COURSE_API_KEY=your-golfcourseapi-key
EXPO_PUBLIC_REVENUECAT_API_KEY=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Stripe (required for real payment flow — get from dashboard.stripe.com)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# URL of the Next.js web server (change to deployed URL in production)
EXPO_PUBLIC_API_URL=http://localhost:3000
