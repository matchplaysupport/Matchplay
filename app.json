{
  "expo": {
    "name": "Match Play",
    "slug": "match-play",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "matchplay",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "requireFullScreen": true,
      "bundleIdentifier": "com.matchplay.mobile",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Match Play uses approximate location to suggest nearby tee times, golfers, and open games."
      }
    },
    "android": {
      "package": "com.matchplay.mobile",
      "permissions": ["ACCESS_COARSE_LOCATION", "ACCESS_FINE_LOCATION"]
    },
    "plugins": ["expo-router", "expo-secure-store", "expo-notifications", "expo-location"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
