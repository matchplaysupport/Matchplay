{
  "expo": {
    "name": "The Clubhouse",
    "slug": "the-clubhouse",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "theclubbhouse",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "requireFullScreen": true,
      "bundleIdentifier": "com.theclubbhouse.mobile",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "The Clubhouse uses approximate location to suggest nearby tee times, golfers, and open games."
      }
    },
    "android": {
      "package": "com.theclubbhouse.mobile",
      "permissions": ["ACCESS_COARSE_LOCATION", "ACCESS_FINE_LOCATION"]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      "expo-location",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.theclubbhouse.mobile",
          "enableGooglePay": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
