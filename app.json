{
  "expo": {
    "name": "The Clubhouse",
    "slug": "the-clubhouse",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon-light.png",
    "scheme": "theclubhouse",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "icon": {
        "light": "./assets/icon-light.png",
        "dark": "./assets/icon-dark.png"
      },
      "supportsTablet": true,
      "requireFullScreen": true,
      "bundleIdentifier": "com.theclubhouse.mobile",
      "buildNumber": "4",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "The Clubhouse uses approximate location to suggest nearby tee times, golfers, and open games.",
        "NSCameraUsageDescription": "The Clubhouse uses the camera to scan your payment card when you save a payment method."
      }
    },
    "android": {
      "package": "com.theclubhouse.mobile",
      "permissions": ["ACCESS_COARSE_LOCATION", "ACCESS_FINE_LOCATION"]
    },
    "splash": {
      "backgroundColor": "#062B24",
      "image": "./assets/logo-dark.png",
      "resizeMode": "contain"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      "expo-location",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.theclubhouse.mobile",
          "enableGooglePay": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
